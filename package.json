{
  "name": "opencli-plugin-awb",
  "version": "0.1.0",
  "description": "LingJing AI Anime Workbench platform CLI plugin for opencli",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LingJingAI-Labs/opencli-plugin-awb.git"
  },
  "homepage": "https://github.com/LingJingAI-Labs/opencli-plugin-awb#readme",
  "bugs": {
    "url": "https://github.com/LingJingAI-Labs/opencli-plugin-awb/issues"
  },
  "keywords": [
    "opencli",
    "plugin",
    "awb",
    "anime-workbench",
    "lingjing"
  ],
  "scripts": {
    "check": "node --check index.js && node --check install.mjs && node --check packages/awb-core/commands.js && node --check packages/awb-core/standalone.js && node --check packages/awb-cli/bin/awb.js",
    "postinstall": "node install.mjs",
    "version:sync": "node scripts/sync-versions.mjs"
  },
  "files": [
    "common.js",
    "index.js",
    "install.mjs",
    "packages/awb-core",
    "README.md"
  ],
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
